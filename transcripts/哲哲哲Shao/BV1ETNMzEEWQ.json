    {
      "start": 2026.58,
      "end": 2113.2799999999997,
      "text": "买1Tikki"
    },
    {
      "start": 2113.2799999999997,
      "end": 2114.2799999999997,
      "text": "Mr."
    },
    {
      "start": 2114.2799999999997,
      "end": 2116.82,
      "text": "啊 不好意思"
    },
    {
      "start": 2116.82,
      "end": 2117.82,
      "text": "啊"
    },
    {
      "start": 2117.82,
      "end": 2120.17,
      "text": "你买1Tikki 买1Tikki"
    },
    {
      "start": 2120.17,
      "end": 2121.17,
      "text": "OK"
    },
    {
      "start": 2123.62,
      "end": 2131.54,
      "text": "很尴尬"
    },
    {
      "start": 2131.54,
      "end": 2133.57,
      "text": "我买1Tikki"
    },
    {
      "start": 2133.57,
      "end": 2135.57,
      "text": "你买1Tikki 买1Tikki"
    },
    {
      "start": 2135.57,
      "end": 2137.57,
      "text": "好 买1Tikki"
    },
    {
      "start": 2137.57,
      "end": 2139.57,
      "text": "16Tikki"
    },
    {
      "start": 2139.57,
      "end": 2141.37,
      "text": "谢谢"
    },
    {
      "start": 2245.07,
      "end": 2247.07,
      "text": "就像演员一样 真的难"
    },
    {
      "start": 2247.07,
      "end": 2249.16,
      "text": "好多人排队"
    },
    {
      "start": 2249.16,
      "end": 2250.16,
      "text": "再排一趟"
    },
    {
      "start": 2250.16,
      "end": 2262.0,
      "text": "下面绝对更便宜"
    },
    {
      "start": 2322.77,
      "end": 2324.27,
      "text": "不知道大家是不是更便宜"
    },
    {
      "start": 2324.27,
      "end": 2325.33,
      "text": "问一下"
    },
    {
      "start": 2325.33,
      "end": 2327.33,
      "text": "果然越往中间 东西越便宜"
    },
    {
      "start": 2327.33,
      "end": 2329.81,
      "text": "真的是无语了"
    },
    {
      "start": 2329.81,
      "end": 2330.81,
      "text": "我之前都是在景区买的"
    },
    {
      "start": 2330.81,
      "end": 2331.81,
      "text": "那个景区买的"
    },
    {
      "start": 2390.16,
      "end": 2391.16,
      "text": "那好了"
    },
    {
      "start": 2391.16,
      "end": 2392.16,
      "text": "我听到了Pontos"
    },
    {
      "start": 2392.16,
      "end": 2394.16,
      "text": "我不知道是不是火车站"
    },
    {
      "start": 2394.16,
      "end": 2396.16,
      "text": "我就一紧张的就下车了"
    },
    {
      "start": 2396.16,
      "end": 2398.16,
      "text": "就发现这里根本就不是火车站"
    },
    {
      "start": 2398.16,
      "end": 2399.16,
      "text": "但是还好 还要半个小时"
    },
    {
      "start": 2399.16,
      "end": 2400.16,
      "text": "而且就离"
    },
    {
      "start": 2400.0,
      "end": 2401.0,
      "text": "雷一點點去"
    },
    {
      "start": 2401.79,
      "end": 2403.59,
      "text": "為什麼這個院子裡會有山羊"
    },
    {
      "start": 2406.05,
      "end": 2407.65,
      "text": "難怪我覺得下車的時候"
    },
    {
      "start": 2407.65,
      "end": 2409.95,
      "text": "好多人發出了問號的感覺"
    },
    {
      "start": 2440.87,
      "end": 2441.97,
      "text": "好有意思的房子"
    },
    {
      "start": 2446.29,
      "end": 2447.29,
      "text": "還好還好"
    },
    {
      "start": 2447.59,
      "end": 2448.59,
      "text": "還好不是"
    },
    {
      "start": 2448.89,
      "end": 2451.39,
      "text": "剩五分鐘剩十分鐘這種時間"
    },
    {
      "start": 2540.1,
      "end": 2697.36,
      "text": "又坐公交車回到了法國"
    },
    {
      "start": 2697.36,
      "end": 2699.09,
      "text": "好神奇啊"
    },
    {
      "start": 2699.09,
      "end": 2700.59,
      "text": "而且是這麼偏僻的地方"
    },
    {
      "start": 2700.59,
      "end": 2701.59,
      "text": "一個人都沒有"
    },
    {
      "start": 2701.59,
      "end": 2704.09,
      "text": "說到法國我就有點害怕了"
    },
    {
      "start": 2704.09,
      "end": 2706.09,
      "text": "只要這邊跟瑞士比較相似吧"
    },
    {
      "start": 2706.09,
      "end": 2713.43,
      "text": "大半夜前沒有人遛狗"
    },
    {
      "start": 2713.43,
      "end": 2716.98,
      "text": "叫我往前走"
    },
    {
      "start": 2716.98,
      "end": 2719.12,
      "text": "什麼山狗狗啊"
    },
    {
      "start": 2719.12,
      "end": 2720.62,
      "text": "我不會被擦掉吧"
    },
    {
      "start": 2720.62,
      "end": 2724.98,
      "text": "糟糕了"
    },
    {
      "start": 2724.98,
      "end": 2728.3,
      "text": "輔了"
    },
    {
      "start": 2728.3,
      "end": 2729.3,
      "text": "最後一晚"
    },
    {
      "start": 2729.3,
      "end": 2786.7200000000003,
      "text": "我現在終於到了歐洲行的最後一個房間"
    },
    {
      "start": 2786.7200000000003,
      "end": 2789.38,
      "text": "好了"
    },
    {
      "start": 2789.38,
      "end": 2790.38,
      "text": "現在感覺沒做好看的"
    },
    {
      "start": 2790.38,
      "end": 2791.88,
      "text": "但是給大家看一下吧"
    },
    {
      "start": 2791.88,
      "end": 2793.38,
      "text": "門口就是這樣"
    },
    {
      "start": 2793.38,
      "end": 2797.3,
      "text": "非常的工業風"
    },
    {
      "start": 2797.3,
      "end": 2801.04,
      "text": "然後房間一張床"
    },
    {
      "start": 2801.04,
      "end": 2803.04,
      "text": "可以攤開箱子的位置"
    },
    {
      "start": 2803.04,
      "end": 2803.54,
      "text": "很不錯"
    },
    {
      "start": 2803.54,
      "end": 2805.04,
      "text": "讓我們來一起來看看"
    },
    {
      "start": 2805.04,
      "end": 2806.54,
      "text": "廁所浴室"
    },
    {
      "start": 2806.54,
      "end": 2809.67,
      "text": "還行吧"
    },
    {
      "start": 2809.67,
      "end": 2811.67,
      "text": "然後最後一晚是"
    },
    {
      "start": 2811.67,
      "end": 2813.77,
      "text": "六百樓將近七百好像"
    },
    {
      "start": 2813.77,
      "end": 2815.77,
      "text": "還是七百樓將近八百我看一下"
    },
    {
      "start": 2815.77,
      "end": 2818.27,
      "text": "是七百九"
    },
    {
      "start": 2818.27,
      "end": 2820.43,
      "text": "這麼偏的地方到七百九"
    },
    {
      "start": 2820.43,
      "end": 2822.43,
      "text": "我為什麼不住近一點呢"
    },
    {
      "start": 2822.43,
      "end": 2823.43,
      "text": "當然是因為貴啊"
    },
    {
      "start": 2823.93,
      "end": 2824.93,
      "text": "動不動就一清涂"
    },
    {
      "start": 2824.93,
      "end": 2826.93,
      "text": "我只是睡一覺而已"
    },
    {
      "start": 2826.93,
      "end": 2829.93,
      "text": "那我趕緊寫個早睡覺了"
    },
    {
      "start": 2829.93,
      "end": 2832.43,
      "text": "我明天打算非常早了起來"
    },
    {
      "start": 2849.61,
      "end": 2851.61,
      "text": "怎麼感覺想像中的短呢"
    },
    {
      "start": 2851.61,
      "end": 2853.61,
      "text": "昨天走了感覺很長在這"
    },
    {
      "start": 2853.61,
      "end": 2879.31,
      "text": "瑞士"
    },
    {
      "start": 2879.31,
      "end": 2901.37,
      "text": "OK"
    },
    {
      "start": 2901.37,
      "end": 2902.37,
      "text": "謝謝你們"
    },
    {
      "start": 2902.37,
      "end": 2903.37,
      "text": "66"
    },
    {
      "start": 2903.37,
      "end": 2904.37,
      "text": "啊對"
    },
    {
      "start": 2904.37,
      "end": 2905.37,
      "text": " Excuse me"
    },
    {
      "start": 2905.37,
      "end": 2906.37,
      "text": "Yep"
    },
    {
      "start": 2906.37,
      "end": 2907.37,
      "text": "He say"
    },
    {
      "start": 2907.37,
      "end": 2909.43,
      "text": "Let's sit his"
    },
    {
      "start": 2909.43,
      "end": 2910.7200000000003,
      "text": " his"
    },
    {
      "start": 2910.7200000000003,
      "end": 2911.7200000000003,
      "text": "呃"
    },
    {
      "start": 2911.7200000000003,
      "end": 2912.7200000000003,
      "text": "Miss his ticket"
    },
    {
      "start": 2912.7200000000003,
      "end": 2913.7200000000003,
      "text": "Oh"
    },
    {
      "start": 2914.2200000000003,
      "end": 2915.2200000000003,
      "text": "Yep"
    },
    {
      "start": 2915.2200000000003,
      "end": 2917.69,
      "text": "Take it"
    },
    {
      "start": 2917.69,
      "end": 2918.69,
      "text": "Excuse me"
    },
    {
      "start": 2918.69,
      "end": 2919.76,
      "text": "Here"
    },
    {
      "start": 2919.76,
      "end": 2921.08,
      "text": "Here you go"
    },
    {
      "start": 2921.08,
      "end": 2924.0,
      "text": "It's his"
    },
    {
      "start": 2924.0,
      "end": 2925.0,
      "text": "He said that"
    },
    {
      "start": 2925.0,
      "end": 2937.07,
      "text": "Oh OK"
    },
    {
      "start": 2937.07,
      "end": 2938.07,
      "text": "This is your ring"
    },
    {
      "start": 3028.46,
      "end": 3031.74,
      "text": "今年9月份歐洲旅行的Vlog到此就徹底結束了"
    },
    {
      "start": 3031.74,
      "end": 3033.66,
      "text": "感謝大家將近半年以來的關注"
    },
    {
      "start": 3033.66,
      "end": 3034.62,
      "text": "我們耐心的等待"
    },
    {
      "start": 3034.62,
      "end": 3035.74,
      "text": "我們下個旅程再見"
    }
