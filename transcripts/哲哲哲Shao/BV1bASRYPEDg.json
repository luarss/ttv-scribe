      "start": 1173.24,
      "end": 1174.24,
      "text": "我的嗓子"
    },
    {
      "start": 1174.24,
      "end": 1175.24,
      "text": "现在有点要废掉了"
    },
    {
      "start": 1175.24,
      "end": 1177.24,
      "text": "现在是个气泡音"
    },
    {
      "start": 1177.24,
      "end": 1178.24,
      "text": "今天本来是约了"
    },
    {
      "start": 1178.24,
      "end": 1180.24,
      "text": "我一个新乡本地的朋友"
    },
    {
      "start": 1180.24,
      "end": 1181.24,
      "text": "就是"
    },
    {
      "start": 1181.24,
      "end": 1182.24,
      "text": "我刚刚约好了"
    },
    {
      "start": 1182.24,
      "end": 1183.24,
      "text": "是1点半"
    },
    {
      "start": 1183.24,
      "end": 1184.24,
      "text": "吃过油肉"
    },
    {
      "start": 1184.24,
      "end": 1185.24,
      "text": "但是呢"
    },
    {
      "start": 1185.24,
      "end": 1186.24,
      "text": "就在刚刚"
    },
    {
      "start": 1186.24,
      "end": 1187.24,
      "text": "就是另一波队友们"
    },
    {
      "start": 1187.24,
      "end": 1189.24,
      "text": "突然叫我一起去吃凉皮"
    },
    {
      "start": 1189.24,
      "end": 1191.24,
      "text": "想想反正有1点半"
    },
    {
      "start": 1191.24,
      "end": 1192.24,
      "text": "还有一个半小时"
    },
    {
      "start": 1192.24,
      "end": 1194.24,
      "text": "这边的凉皮我也没吃过"
    },
    {
      "start": 1194.24,
      "end": 1196.24,
      "text": "那就吃两顿吧"
    },
    {
      "start": 1196.24,
      "end": 1197.24,
      "text": "现在我在收拾东西"
    },
    {
      "start": 1197.24,
      "end": 1198.24,
      "text": "直接等着"
    },
    {
      "start": 1198.24,
      "end": 1199.24,
      "text": "直接拖着行李箱就够了"
    },
    {
      "start": 1200.0,
      "end": 1200.5,
      "text": "不去"
    },
    {
      "start": 1201.0,
      "end": 1202.0,
      "text": "就決定說拜拜"
    },
    {
      "start": 1203.0,
      "end": 1203.5,
      "text": "拜拜"
    },
    {
      "start": 1204.0,
      "end": 1205.0,
      "text": "看了那個乾濕"
    },
    {
      "start": 1206.19,
      "end": 1206.69,
      "text": "害怕吧"
    },
    {
      "start": 1207.29,
      "end": 1208.29,
      "text": "呃還好吧"
    },
    {
      "start": 1208.29,
      "end": 1209.29,
      "text": "旁邊都是人"
    },
    {
      "start": 1209.29,
      "end": 1211.29,
      "text": "不怕你一個人去的話"
    },
    {
      "start": 1211.29,
      "end": 1212.29,
      "text": "如果有什麼殺氣的話"
    },
    {
      "start": 1212.29,
      "end": 1213.29,
      "text": "早就不行了"
    },
    {
      "start": 1213.29,
      "end": 1215.29,
      "text": "人在保護管成立的東西"
    },
    {
      "start": 1215.29,
      "end": 1218.29,
      "text": "他已經就是說是做過那種的"
    },
    {
      "start": 1218.29,
      "end": 1219.29,
      "text": "是吧"
    },
    {
      "start": 1219.29,
      "end": 1220.29,
      "text": "處理了"
    },
    {
      "start": 1220.29,
      "end": 1221.29,
      "text": "對他不可能說"
    },
    {
      "start": 1221.29,
      "end": 1222.29,
      "text": "來一個人就嚇死了"
    },
    {
      "start": 1222.29,
      "end": 1223.29,
      "text": "不可能"
    },
    {
      "start": 1223.29,
      "end": 1224.29,
      "text": "啊那這樣車在冒煙"
    },
    {
      "start": 1225.29,
      "end": 1226.29,
      "text": "還給他演一演"
    },
    {
      "start": 1226.29,
      "end": 1227.29,
      "text": "咱們沒他演一演一點"
    },
    {
      "start": 1227.29,
      "end": 1228.29,
      "text": "啊"
    },
    {
      "start": 1228.29,
      "end": 1229.29,
      "text": "都沒"
    },
    {
      "start": 1230.29,
      "end": 1231.29,
      "text": "好"
    },
    {
      "start": 1232.29,
      "end": 1233.29,
      "text": "後臂向前"
    },
    {
      "start": 1233.29,
      "end": 1234.29,
      "text": "好的好的再見囉"
    },
    {
      "start": 1234.29,
      "end": 1235.29,
      "text": "拜拜"
    },
    {
      "start": 1235.29,
      "end": 1237.29,
      "text": "歡迎你再來新疆"
    },
    {
      "start": 1241.52,
      "end": 1243.52,
      "text": "嗨你又知道我來了"
    },
    {
      "start": 1243.52,
      "end": 1245.52,
      "text": "我看到你的心臟了"
    },
    {
      "start": 1247.0,
      "end": 1248.0,
      "text": "從來"
    },
    {
      "start": 1249.0,
      "end": 1250.0,
      "text": "呃梁高"
    },
    {
      "start": 1252.28,
      "end": 1253.28,
      "text": "呃梁皮"
    },
    {
      "start": 1253.28,
      "end": 1254.28,
      "text": "那盤牛肌"
    },
    {
      "start": 1254.28,
      "end": 1255.28,
      "text": "青菜"
    },
    {
      "start": 1255.28,
      "end": 1256.28,
      "text": "你現在的磚"
    },
    {
      "start": 1256.28,
      "end": 1257.28,
      "text": "那腿的汁"
    },
    {
      "start": 1257.28,
      "end": 1258.28,
      "text": "那紫衣"
    },
    {
      "start": 1258.28,
      "end": 1259.28,
      "text": "那肢"
    },
    {
      "start": 1259.28,
      "end": 1260.28,
      "text": "那肢"
    },
    {
      "start": 1260.28,
      "end": 1264.67,
      "text": "準備好了"
    },
    {
      "start": 1264.67,
      "end": 1270.25,
      "text": "再補一下"
    },
    {
      "start": 1271.25,
      "end": 1277.02,
      "text": "我覺得這個"
    },
    {
      "start": 1278.02,
      "end": 1279.02,
      "text": "辣皮子"
    },
    {
      "start": 1280.02,
      "end": 1281.02,
      "text": "辣椒"
    },
    {
      "start": 1281.02,
      "end": 1282.02,
      "text": "哪一個"
    },
    {
      "start": 1282.02,
      "end": 1283.02,
      "text": "奧車來了"
    },
    {
      "start": 1283.02,
      "end": 1284.02,
      "text": "拜拜"
    },
    {
      "start": 1284.02,
      "end": 1285.02,
      "text": "拜拜"
    },
    {
      "start": 1285.02,
      "end": 1286.02,
      "text": "拜拜"
    },
    {
      "start": 1286.02,
      "end": 1287.18,
      "text": "拜拜"
    },
    {
      "start": 1290.53,
      "end": 1291.53,
      "text": "拜拜"
    },
    {
      "start": 1291.53,
      "end": 1292.53,
      "text": "拜拜"
    },
    {
      "start": 1293.53,
      "end": 1299.46,
      "text": "我們那邊美男"
    },
    {
      "start": 1299.46,
      "end": 1300.46,
      "text": "有好多不一樣的"
    },
    {
      "start": 1300.46,
      "end": 1301.46,
      "text": "就是"
    },
    {
      "start": 1301.46,
      "end": 1303.67,
      "text": "我們從"
    },
    {
      "start": 1303.67,
      "end": 1305.67,
      "text": "三亞開車道"
    },
    {
      "start": 1313.92,
      "end": 1317.42,
      "text": "我真的受不了了"
    },
    {
      "start": 1317.42,
      "end": 1318.42,
      "text": "怎麼又能"
    },
    {
      "start": 1318.42,
      "end": 1319.42,
      "text": "燦當"
    },
    {
      "start": 1319.42,
      "end": 1320.42,
      "text": "火加火"
    },
    {
      "start": 1320.42,
      "end": 1322.42,
      "text": "我也是這個事"
    },
    {
      "start": 1322.42,
      "end": 1323.42,
      "text": "那我先走了"
    },
    {
      "start": 1323.42,
      "end": 1324.49,
      "text": "拜拜"
    },
    {
      "start": 1324.49,
      "end": 1325.49,
      "text": "拜拜"
    }
  ],
