    {
      "start": 2046.98,
      "end": 2049.26,
      "text": "對喔"
    },
    {
      "start": 2049.26,
      "end": 2050.26,
      "text": "我試一下"
    },
    {
      "start": 2050.26,
      "end": 2051.26,
      "text": "我想一下"
    },
    {
      "start": 2051.26,
      "end": 2055.11,
      "text": "按到你幫我按一下電"
    },
    {
      "start": 2055.11,
      "end": 2056.11,
      "text": "好"
    },
    {
      "start": 2056.11,
      "end": 2070.26,
      "text": "出事"
    },
    {
      "start": 2070.26,
      "end": 2125.35,
      "text": "我們就在那裡我想回家"
    },
    {
      "start": 2125.35,
      "end": 2143.18,
      "text": "開七公里"
    },
    {
      "start": 2143.18,
      "end": 2169.05,
      "text": "還有這麼長"
    },
    {
      "start": 2169.05,
      "end": 2243.54,
      "text": "他這個備用電池是有電"
    },
    {
      "start": 2243.54,
      "end": 2245.54,
      "text": "但是他就是用不了"
    },
    {
      "start": 2254.06,
      "end": 2271.7,
      "text": "可以吧"
    },
    {
      "start": 2271.7,
      "end": 2274.14,
      "text": "我覺得我要感冒了"
    },
    {
      "start": 2274.14,
      "end": 2281.3,
      "text": "喝不了冰奶茶了嗎"
    },
    {
      "start": 2281.3,
      "end": 2282.3,
      "text": "這麼小的老鼠"
    },
    {
      "start": 2282.3,
      "end": 2330.18,
      "text": "他不要下去"
    },
    {
      "start": 2330.18,
      "end": 2332.41,
      "text": "他最後沒有收五千"
    },
    {
      "start": 2332.41,
      "end": 2333.41,
      "text": "我現在"
    },
    {
      "start": 2333.41,
      "end": 2334.41,
      "text": "好啦"
    },
    {
      "start": 2334.41,
      "end": 2335.41,
      "text": "這視頻"
    },
    {
      "start": 2335.41,
      "end": 2337.82,
      "text": "真的到這裡結束了"
    },
    {
      "start": 2337.82,
      "end": 2338.82,
      "text": "不想再錄了"
    },
    {
      "start": 2338.82,
      "end": 2343.42,
      "text": "趕快找個地方喝熱的東西"
    },
    {
      "start": 2344.42,
      "end": 2346.42,
      "text": "我有看到你小紅書裡面"
    },
    {
      "start": 2346.42,
      "end": 2348.42,
      "text": "沒有拍我們車長片的時候"
    },
    {
      "start": 2349.46,
      "end": 2350.46,
      "text": "啊"
    },
    {
      "start": 2350.46,
      "end": 2352.45,
      "text": "對喔"
    },
    {
      "start": 2352.45,
      "end": 2353.45,
      "text": "你已經刷到了"
    },
    {
      "start": 2353.45,
      "end": 2355.45,
      "text": "你又想說這不是金門大橋"
    },
    {
      "start": 2355.45,
      "end": 2357.45,
      "text": "那個銀色銷售"
    },
    {
      "start": 2357.45,
      "end": 2358.45,
      "text": "好的"
    },
    {
      "start": 2358.45,
      "end": 2359.45,
      "text": "好 你最帥"
    },
    {
      "start": 2361.45,
      "end": 2362.45,
      "text": "好的"
    }
  ],
