      "start": 425.64,
      "end": 427.68,
      "text": "看到有人在這飛無人機"
    },
    {
      "start": 427.68,
      "end": 477.3,
      "text": "那我也來飛一下"
    },
    {
      "start": 477.3,
      "end": 478.18,
      "text": "那沒洗吧"
    },
    {
      "start": 478.18,
      "end": 478.78,
      "text": "可以"
    },
    {
      "start": 482.47,
      "end": 484.87,
      "text": "那也當然什麼時候回國"
    },
    {
      "start": 484.87,
      "end": 485.71,
      "text": "還有一個月吧"
    },
    {
      "start": 485.71,
      "end": 487.23,
      "text": "哇牛"
    },
    {
      "start": 487.23,
      "end": 489.11,
      "text": "我還沒有帶不了這麼久"
    },
    {
      "start": 489.11,
      "end": 506.38,
      "text": "祝親女"
    },
    {
      "start": 506.38,
      "end": 507.42,
      "text": "祝親女"
    },
    {
      "start": 507.42,
      "end": 509.01,
      "text": "祝我辦公室"
    },
    {
      "start": 509.01,
      "end": 510.53,
      "text": "但是要把根預先做好"
    },
    {
      "start": 510.53,
      "end": 511.13,
      "text": "這也漂亮"
    },
    {
      "start": 511.13,
      "end": 513.05,
      "text": "我這3月之前就訂了"
    },
    {
      "start": 513.05,
      "end": 513.61,
      "text": "這樣的話"
    },
    {
      "start": 513.61,
      "end": 514.33,
      "text": "其實他就"
    },
    {
      "start": 514.33,
      "end": 515.17,
      "text": "不需要多一點"
    },
    {
      "start": 515.17,
      "end": 516.49,
      "text": "你就贏背包"
    },
    {
      "start": 516.49,
      "end": 517.33,
      "text": "就走了"
    },
    {
      "start": 517.33,
      "end": 519.78,
      "text": "然後有的就坐船"
    },
    {
      "start": 519.78,
      "end": 521.78,
      "text": "有地方就坐80公里"
    },
    {
      "start": 521.78,
      "end": 522.42,
      "text": "然後我們這一步"
    },
    {
      "start": 522.42,
      "end": 523.58,
      "text": "調補太多"
    },
    {
      "start": 523.58,
      "end": 524.78,
      "text": "這種工業我得"
    },
    {
      "start": 524.78,
      "end": 525.38,
      "text": "做一年"
    },
    {
      "start": 526.94,
      "end": 528.18,
      "text": "那也是辭職過來的嗎"
    },
    {
      "start": 528.18,
      "end": 528.46,
      "text": "還是"
    },
    {
      "start": 528.46,
      "end": 529.06,
      "text": "不一定的"
    },
    {
      "start": 529.06,
      "end": 529.78,
      "text": "好"
    },
    {
      "start": 529.78,
      "end": 531.02,
      "text": "剛才哪有這麼好駕"
    },
    {
      "start": 531.02,
      "end": 531.78,
      "text": "我什麼時候"
    },
    {
      "start": 533.78,
      "end": 534.78,
      "text": "你怎麼覺得外面的人"
    },
    {
      "start": 534.78,
      "end": 537.26,
      "text": "感覺生活狀態完全都不一樣"
    },
    {
      "start": 537.26,
      "end": 537.86,
      "text": "一樣啊"
    },
    {
      "start": 537.86,
      "end": 539.75,
      "text": "這是我到西班牙的時候"
    },
    {
      "start": 539.75,
      "end": 540.43,
      "text": "我都"
    },
    {
      "start": 540.43,
      "end": 541.27,
      "text": "蠻以前聽到"
    },
    {
      "start": 541.27,
      "end": 542.75,
      "text": "大蝦舞的那種唱歌"
    },
    {
      "start": 542.75,
      "end": 544.07,
      "text": "就是風原歌詩"
    },
    {
      "start": 544.07,
      "end": 544.99,
      "text": "等日落了"
    },
    {
      "start": 544.99,
      "end": 545.91,
      "text": "我就在"
    },
    {
      "start": 545.91,
      "end": 547.39,
      "text": "我是在那的時候"
    },
    {
      "start": 547.43,
      "end": 548.27,
      "text": "上午11點鐘"
    },
    {
      "start": 548.27,
      "end": 549.83,
      "text": "我全都躺在那個隔壁"
    },
    {
      "start": 549.83,
      "end": 551.43,
      "text": "就摸摸放一個冰箱"
    },
    {
      "start": 551.43,
      "end": 553.11,
      "text": "我到西班牙的時候"
    },
    {
      "start": 553.11,
      "end": 554.11,
      "text": "哎呀 我就在那邊聊"
    },
    {
      "start": 554.11,
      "end": 554.87,
      "text": "我就在那邊聊"
    },
    {
      "start": 554.87,
      "end": 556.35,
      "text": "我說"
    },
    {
      "start": 556.35,
      "end": 557.35,
      "text": "你不用工作嗎"
    },
    {
      "start": 557.35,
      "end": 557.91,
      "text": "對呀"
    },
    {
      "start": 557.91,
      "end": 559.03,
      "text": "幾公分的事"
    },
    {
      "start": 559.03,
      "end": 559.55,
      "text": "我還聽了"
    },
    {
      "start": 559.55,
      "end": 560.67,
      "text": "為什麼你在那"
    },
    {
      "start": 560.67,
      "end": 561.59,
      "text": "在那兒躺著呢"
    },
    {
      "start": 561.59,
      "end": 563.35,
      "text": "他跟我說"
    },
    {
      "start": 563.35,
      "end": 564.47,
      "text": "躺著嗎"
    },
    {
      "start": 564.47,
      "end": 565.15,
      "text": "他說"
    },
    {
      "start": 565.15,
      "end": 565.87,
      "text": "我說為什麼"
    },
    {
      "start": 565.87,
      "end": 566.67,
      "text": "他說"
    },
    {
      "start": 566.67,
      "end": 568.59,
      "text": "在這人類都是這樣子的"
    },
    {
      "start": 568.59,
      "end": 569.15,
      "text": "因為在維修"
    },
    {
      "start": 569.15,
      "end": 570.19,
      "text": "你把我吃點東西"
    },
    {
      "start": 570.19,
      "end": 571.15,
      "text": "都躺在那邊"
    },
    {
      "start": 571.15,
      "end": 571.51,
      "text": "假的吧"
    },
    {
      "start": 571.51,
      "end": 572.35,
      "text": "我坐了"
    },
    {
      "start": 572.35,
      "end": 572.99,
      "text": "坐了"
    },
    {
      "start": 572.99,
      "end": 574.91,
      "text": "大家就躺在這"
    },
    {
      "start": 574.91,
      "end": 575.59,
      "text": "在太陽"
    },
    {
      "start": 575.59,
      "end": 576.75,
      "text": "其實我就覺得"
    },
    {
      "start": 576.75,
      "end": 577.87,
      "text": "在我最以為很多地方"
    },
    {
      "start": 577.87,
      "end": 578.55,
      "text": "之後發現"
    },
    {
      "start": 578.55,
      "end": 579.55,
      "text": "哪個地方還有好地方"
    },
    {
      "start": 579.55,
      "end": 580.27,
      "text": "也不好的地方"
    },
    {
      "start": 580.27,
      "end": 582.23,
      "text": "然後就是你如果"
    },
    {
      "start": 582.23,
      "end": 583.75,
      "text": "長期在一種環境下面的話"
    },
    {
      "start": 583.75,
      "end": 584.79,
      "text": "覺得焦慮"
    },
    {
      "start": 584.79,
      "end": 585.35,
      "text": "就是覺得"
    },
    {
      "start": 585.35,
      "end": 585.99,
      "text": "無聊啊"
    },
    {
      "start": 585.99,
      "end": 586.91,
      "text": "有時候也覺得"
    },
    {
      "start": 586.91,
      "end": 587.47,
      "text": "太安逸了"
    },
    {
      "start": 587.47,
      "end": 588.67,
      "text": "但是他想去亞洲呢"
    },
    {
      "start": 588.67,
      "end": 590.19,
      "text": "這個真的還"
    },
    {
      "start": 590.19,
      "end": 590.47,
      "text": "對"
    },
    {
      "start": 590.47,
      "end": 591.59,
      "text": "就讓他體驗一下"
    },
    {
      "start": 591.59,
      "end": 592.67,
      "text": "他待了10年後"
    },
    {
      "start": 592.67,
      "end": 593.59,
      "text": "他也感覺會"
    },
    {
      "start": 593.59,
      "end": 594.43,
      "text": "不用一年"
    },
    {
      "start": 594.43,
      "end": 595.23,
      "text": "不用一年"
    },
    {
      "start": 595.23,
      "end": 596.75,
      "text": "你還是別懷疑"
    },
    {
      "start": 596.75,
      "end": 597.75,
      "text": "這地方拜託我"
    },
    {
      "start": 597.75,
      "end": 598.75,
      "text": "但是他們這邊"
    },
    {
      "start": 598.75,
      "end": 599.39,
      "text": "比較不方便"
    },
    {
      "start": 599.39,
      "end": 599.99,
      "text": "很方便"
    },
    {
      "start": 600.0,
      "end": 601.0,
      "text": "我們就說這個"
    },
    {
      "start": 615.1,
      "end": 663.18,
      "text": "他們對狗也很好"
    },
    {
      "start": 701.52,
      "end": 726.05,
      "text": "看看下一站"
    },
    {
      "start": 726.05,
      "end": 728.4,
      "text": "我們的滑板車"
    },
    {
      "start": 728.4,
      "end": 733.08,
      "text": "看一下能不能騎"
    },
    {
      "start": 781.05,
      "end": 782.05,
      "text": "前面的車子會轉過來"
    },
    {
      "start": 782.05,
      "end": 783.05,
      "text": "對"
    },
    {
      "start": 783.05,
      "end": 784.46,
      "text": "對"
    },
    {
      "start": 784.46,
      "end": 786.46,
      "text": "從右邊到右邊"
    },
    {
      "start": 786.46,
      "end": 856.4300000000001,
      "text": "好 謝謝"
    },
    {
      "start": 856.4300000000001,
      "end": 858.4300000000001,
      "text": "我稍微聊一鬆開一點"
    },
    {
      "start": 858.4300000000001,
      "end": 908.53,
      "text": "我的魂感覺就要跟著飄出去"
    },
    {
      "start": 908.53,
      "end": 909.53,
      "text": "幫我"
    },
    {
      "start": 909.53,
      "end": 911.53,
      "text": "謝謝"
    },
    {
      "start": 911.53,
      "end": 914.23,
      "text": "在裡面"
    },
    {
      "start": 914.23,
      "end": 915.23,
      "text": "謝謝"
    },
    {
      "start": 1092.94,
      "end": 1093.94,
      "text": "為能不能等我幾分鐘"
    },
    {
      "start": 1093.94,
      "end": 1094.94,
      "text": "沒想到他們說可以在"
    },
    {
      "start": 1094.94,
      "end": 1095.94,
      "text": "英特拉肯東站捷舞"
    },
    {
      "start": 1095.94,
      "end": 1096.94,
      "text": "這樣子我不用換成"
    },
    {
      "start": 1096.94,
      "end": 1097.94,
      "text": "應該是可以感謝"
    },
    {
      "start": 1097.94,
      "end": 1098.94,
      "text": "前提示"
    },
    {
      "start": 1098.94,
      "end": 1100.94,
      "text": "我也坐上這輛車"
    },
    {
      "start": 1208.37,
      "end": 1215.42,
      "text": " I'm so sorry."
    },
    {
      "start": 1215.42,
      "end": 1217.42,
      "text": " What's your name?"
    },
    {
      "start": 1217.42,
      "end": 1219.42,
      "text": " Wang."
    },
    {
      "start": 1219.42,
      "end": 1221.42,
      "text": " Sorry."
    },
    {
      "start": 1221.42,
      "end": 1223.42,
      "text": " We're going to leave your bags at our desk."
    },
    {
      "start": 1223.42,
      "end": 1225.42,
      "text": " Okay."
    },
    {
      "start": 1225.42,
      "end": 1227.42,
      "text": " Bring with you"
    },
    {
      "start": 1227.42,
      "end": 1229.42,
      "text": " sunglasses"
    },
    {
      "start": 1229.42,
      "end": 1231.42,
      "text": " mobile phone and your wallet."
    },
    {
      "start": 1231.42,
      "end": 1233.42,
      "text": " With the big cameras and the bags, we will have to leave."
    },
    {
      "start": 1233.42,
      "end": 1235.42,
      "text": " Okay, I've put here?"
    },
    {
      "start": 1235.42,
      "end": 1237.42,
      "text": " Yes, and bring your GoPro. Bring that."
    },
    {
      "start": 1237.42,
      "end": 1239.42,
      "text": " Okay."
    },
    {
      "start": 1239.42,
      "end": 1241.42,
      "text": " They will look and see if you can use it."
    },
    {
      "start": 1241.42,
      "end": 1243.42,
      "text": " They will check on the way up."
    },
    {
      "start": 1243.42,
      "end": 1245.42,
      "text": " On the spot bag?"
    },
    {
      "start": 1245.42,
      "end": 1248.64,
      "text": " If we have space."
    },
    {
      "start": 1248.64,
      "end": 1252.94,
      "text": " Now,"
    },
    {
      "start": 1252.94,
      "end": 1275.94,
      "text": " every shot."
    },
    {
      "start": 1275.94,
      "end": 1277.94,
      "text": " The helmets, the harnesses, everything else."
    },
    {
      "start": 1277.94,
      "end": 1279.94,
      "text": " When we are ready to go,"
    },
    {
      "start": 1279.94,
      "end": 1281.94,
      "text": " we will say to you, are you ready?"
    },
    {
      "start": 1281.94,
      "end": 1283.94,
      "text": " You give us a big thumbs up. We'll count it down."
    },
    {
      "start": 1283.94,
      "end": 1285.94,
      "text": " Three, two, one, go."
    },
    {
      "start": 1285.94,
      "end": 1287.94,
      "text": " You need to stay up on your feet."
    },
    {
      "start": 1287.94,
      "end": 1289.94,
      "text": " And run, run, run, run, run."
    },
    {
      "start": 1289.94,
      "end": 1291.94,
      "text": " Okay, pal, pal, pal, pal, pal."
    },
    {
      "start": 1291.94,
      "end": 1293.94,
      "text": " Do you understand my English?"
    },
    {
      "start": 1293.94,
      "end": 1295.94,
      "text": " Yeah."
    },
    {
      "start": 1295.94,
      "end": 1297.94,
      "text": " Because if you don't like us doing a little bit like this,"
    },
    {
      "start": 1297.94,
      "end": 1299.94,
      "text": " you're probably not going to like the more hardcore"
    },
    {
      "start": 1299.94,
      "end": 1301.94,
      "text": " spiraling."
    },
    {
      "start": 1301.94,
      "end": 1303.94,
      "text": " Relax. Do you guys fight?"
    },
    {
      "start": 1303.94,
      "end": 1305.94,
      "text": " Remember, run, run, run, run, run."
    },
    {
      "start": 1305.94,
      "end": 1307.94,
      "text": " Pal, pal, pal, pal, pal."
    },
    {
      "start": 1307.94,
      "end": 1309.94,
      "text": " Try not to scream while we're doing that."
    },
    {
      "start": 1309.94,
      "end": 1311.94,
      "text": " Okay, relax."
    },
    {
      "start": 1311.94,
      "end": 1313.94,
      "text": " And I have your camera. We need to put a safety leash on it, okay?"
    },
    {
      "start": 1313.94,
      "end": 1315.94,
      "text": " Okay."
    },
    {
      "start": 1315.94,
      "end": 1317.94,
      "text": " You can take your camera off."
    },
    {
      "start": 1317.94,
      "end": 1319.94,
      "text": " And we need to put it safe to the street."
    },
    {
      "start": 1319.94,
      "end": 1330.1,
      "text": " It's real."
    },
    {
      "start": 1330.93,
      "end": 1332.99,
      "text": " Yeah, yeah."
    },
    {
      "start": 1332.99,
      "end": 1334.99,
      "text": " Korean is supposed to be very simple."
    },
    {
      "start": 1334.99,
      "end": 1339.94,
      "text": " I've read the story about the Korean language."
    },
    {
      "start": 1339.94,
      "end": 1342.94,
      "text": " It was because they were trying to learn Chinese."
    },
    {
      "start": 1342.94,
      "end": 1345.94,
      "text": " And the king of Korea hated that because it..."
    },
    {
      "start": 1345.94,
      "end": 1423.94,
      "text": " The only way, okay?"
    },
    {
      "start": 1423.94,
      "end": 1427.94,
      "text": " Just keep it. Then we are sure, okay?"
    },
    {
      "start": 1427.94,
      "end": 1438.7,
      "text": " Very good."
    },
    {
      "start": 1438.7,
      "end": 1468.93,
      "text": " When we come back,"
    },
    {
      "start": 1468.93,
      "end": 1482.6399999999999,
      "text": " stop touching here."
    },
    {
      "start": 1482.6399999999999,
      "end": 1484.6399999999999,
      "text": " Relax. This is..."
    },
    {
      "start": 1484.6399999999999,
      "end": 1486.9,
      "text": " Oh, okay."
    },
    {
      "start": 1486.9,
      "end": 1489.47,
      "text": " Stop moving."
    },
    {
      "start": 1489.47,
      "end": 1491.47,
      "text": " This is for nothing."
    },
    {
      "start": 1491.47,
      "end": 1496.1,
      "text": " This is not the goal."
    },
    {
      "start": 1496.1,
      "end": 1498.1,
      "text": " Okay? Sorry."
    },
    {
      "start": 1498.1,
      "end": 1500.6399999999999,
      "text": " Happy one?"
    },
    {
      "start": 1500.6399999999999,
      "end": 1502.6399999999999,
      "text": " Are you happy?"
    },
    {
      "start": 1502.6399999999999,
      "end": 1504.6399999999999,
      "text": " Are you okay? Happy to fly?"
    },
    {
      "start": 1504.6399999999999,
      "end": 1506.6399999999999,
      "text": " Very good."
    },
    {
      "start": 1506.6399999999999,
      "end": 1508.6399999999999,
      "text": " So, now we are ready."
    },
    {
      "start": 1508.6399999999999,
      "end": 1510.6399999999999,
      "text": " A nice jacket."
    },
    {
      "start": 1510.6399999999999,
      "end": 1512.6399999999999,
      "text": " We look like a professional pilot."
    },
    {
      "start": 1512.6399999999999,
      "end": 1514.6399999999999,
      "text": " You understand?"
    },
    {
      "start": 1514.6399999999999,
      "end": 1516.6399999999999,
      "text": " Yes."
    },
    {
      "start": 1858.58,
      "end": 1859.54,
      "text": "High-five"
    },
    {
      "start": 1860.86,
      "end": 1914.01,
      "text": "我感觉会被吐槽很多次"
    },
    {
      "start": 1914.01,
      "end": 1914.93,
      "text": "迷远了"
    },
    {
      "start": 1914.93,
      "end": 1915.97,
      "text": "别人没听懂"
    },
    {
      "start": 1915.97,
      "end": 1916.41,
      "text": "听懂了"
    },
    {
      "start": 1916.41,
      "end": 1919.21,
      "text": "他说你是不是完全不懂我在说什么"
    },
    {
      "start": 1919.21,
      "end": 1920.37,
      "text": "我说yes"
    },
    {
      "start": 1920.37,
      "end": 1922.57,
      "text": "现在赶回去超选买点东西"
    },
    {
      "start": 1922.57,
      "end": 1924.77,
      "text": "回去在天黑之前"
    },
    {
      "start": 1924.77,
      "end": 1927.25,
      "text": "酒店最后享受一碗"
    },
    {
      "start": 1935.31,
      "end": 1936.91,
      "text": "只买了几瓶水"
    },
    {
      "start": 1952.83,
      "end": 1954.55,
      "text": "大家都说过的鸡腿"
    },
    {
      "start": 1954.55,
      "end": 1957.18,
      "text": "还有一瓶前两天"
    },
    {
      "start": 1957.18,
      "end": 1958.78,
      "text": "他们就推荐了一碗奶"
    },
    {
      "start": 1958.78,
      "end": 1961.69,
      "text": "那我们看看多少钱"
    },
    {
      "start": 1966.46,
      "end": 2057.87,
      "text": "给我看看"
    },
    {
      "start": 2057.87,
      "end": 2058.43,
      "text": "来看看"
    },
    {
      "start": 2058.43,
      "end": 2059.79,
      "text": "楼下的餐厅演出"
    },
    {
      "start": 2059.79,
      "end": 2176.51,
      "text": "不浪费这么好的趁现在煮泡面"
    },
    {
      "start": 2176.51,
      "end": 2309.64,
      "text": "我们节假今天玩的游戏"
    },
    {
      "start": 2309.64,
      "end": 2312.12,
      "text": "非常可惜没有玩到卡丁车"
    },
    {
      "start": 2312.12,
      "end": 2315.48,
      "text": "不过我个人觉得花瓣车也很好玩"
    },
    {
      "start": 2315.48,
      "end": 2320.4,
      "text": "但是在网上评分大家普遍低于卡丁车和飞翼"
    },
    {
      "start": 2320.4,
      "end": 2321.8,
      "text": "但是我觉得已经很好玩了"
    },
    {
      "start": 2321.8,
      "end": 2323.68,
      "text": "还好今天是赶上了华翔伞"
    },
    {
      "start": 2323.68,
      "end": 2325.88,
      "text": "不然1700块就白白泡汤了"
    },
    {
      "start": 2325.88,
      "end": 2327.88,
      "text": "那个华翔伞真的好刺激"
    },
    {
      "start": 2327.88,
      "end": 2329.24,
      "text": "我第一次滑这种东西"
    },
    {
      "start": 2329.24,
      "end": 2330.48,
      "text": "特别是那个翘�"
    },
    {
      "start": 2330.56,
      "end": 2332.36,
      "text": "就是它后面中间"
    },
    {
      "start": 2333.24,
      "end": 2335.88,
      "text": "它中间就是就开始整合"
    },
    {
      "start": 2335.88,
      "end": 2336.76,
      "text": "击转弯"
    },
    {
      "start": 2337.24,
      "end": 2338.48,
      "text": "right"
    },
    {
      "start": 2339.0,
      "end": 2340.04,
      "text": "lift"
    },
    {
      "start": 2340.04,
      "end": 2342.52,
      "text": "我吓死我了"
    },
    {
      "start": 2342.52,
      "end": 2344.16,
      "text": "然后接转弯弯弯"
    },
    {
      "start": 2344.16,
      "end": 2345.96,
      "text": "然后突然会停一下来一下"
    },
    {
      "start": 2345.96,
      "end": 2348.12,
      "text": "然后就会有一点那下坠的感觉"
    },
    {
      "start": 2348.12,
      "end": 2349.04,
      "text": "然后来就会说"
    },
    {
      "start": 2349.04,
      "end": 2349.8,
      "text": "啊哦"
    },
    {
      "start": 2349.8,
      "end": 2350.8,
      "text": "真的很吓人"
    },
    {
      "start": 2351.8,
      "end": 2353.04,
      "text": "但是真的很刺激"
    },
    {
      "start": 2353.7200000000003,
      "end": 2355.12,
      "text": "那么我要洗几岁了"
    },
    {
      "start": 2355.92,
      "end": 2357.04,
      "text": "从我的口袋里"
    },
    {
      "start": 2358.17,
      "end": 2359.93,
      "text": "挖出了解释带"
    },
    {
      "start": 2360.82,
      "end": 2361.98,
      "text": "不知道我解释带在家里"
    },
    {
      "start": 2361.98,
      "end": 2363.46,
      "text": "六亿部队了怎么样了"
    },
    {
      "start": 2363.46,
      "end": 2364.82,
      "text": "应该很崩溃吧"
    },
    {
      "start": 2364.82,
      "end": 2366.26,
      "text": "一定要入两次"
    },
    {
      "start": 2366.26,
      "end": 2367.06,
      "text": "挖啊"
    },
    {
      "start": 2367.06,
      "end": 2368.26,
      "text": "马卡巴卡"
    }
