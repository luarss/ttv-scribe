      "text": "走吧"
    },
    {
      "start": 1100.03,
      "end": 1105.04,
      "text": "没什么遗憾"
    },
    {
      "start": 1105.04,
      "end": 1106.04,
      "text": "他会躲我"
    },
    {
      "start": 1106.04,
      "end": 1111.74,
      "text": "跑不过他"
    },
    {
      "start": 1111.74,
      "end": 1112.74,
      "text": "就跳过去了"
    },
    {
      "start": 1112.74,
      "end": 1127.9299999999998,
      "text": "跳了跳了跳哪去了"
    },
    {
      "start": 1127.9299999999998,
      "end": 1131.9299999999998,
      "text": "在森林在小溪在荒野"
    },
    {
      "start": 1131.9299999999998,
      "end": 1134.12,
      "text": "我寻找奇迹"
    },
    {
      "start": 1134.12,
      "end": 1143.42,
      "text": "有松树有滩石没有"
    },
    {
      "start": 1143.42,
      "end": 1151.46,
      "text": "在滴滴的铁路旁进行"
    },
    {
      "start": 1151.46,
      "end": 1153.81,
      "text": "无声的哄你"
    },
    {
      "start": 1153.81,
      "end": 1161.71,
      "text": "想记起心底记曾灭你"
    },
    {
      "start": 1161.71,
      "end": 1163.8400000000001,
      "text": "只有你生意"
    },
    {
      "start": 1168.2,
      "end": 1170.3600000000001,
      "text": "看不见他们看得到我"
    },
    {
      "start": 1170.3600000000001,
      "end": 1173.8,
      "text": "我走"
    },
    {
      "start": 1173.8,
      "end": 1174.8,
      "text": "看我直接跑了"
    },
    {
      "start": 1174.8,
      "end": 1175.8,
      "text": "哇"
    },
    {
      "start": 1175.8,
      "end": 1184.01,
      "text": "跟人开开我让他们去"
    },
    {
      "start": 1184.01,
      "end": 1186.06,
      "text": "我们在对面"
    },
    {
      "start": 1186.06,
      "end": 1189.22,
      "text": "我们在室里"
    },
    {
      "start": 1189.22,
      "end": 1190.22,
      "text": "放一句狂奔"
    },
    {
      "start": 1190.22,
      "end": 1191.5,
      "text": "我先回去"
    },
    {
      "start": 1191.5,
      "end": 1193.5,
      "text": "我看到狐狸的地方"
    },
    {
      "start": 1193.5,
      "end": 1195.08,
      "text": "再看一下"
    },
    {
      "start": 1195.08,
      "end": 1197.08,
      "text": "能不能从马路上"
    },
    {
      "start": 1197.08,
      "end": 1199.24,
      "text": "观察到刚刚那一圈"
    },
    {
      "start": 1200.08,
      "end": 1203.67,
      "text": "这里还是比较呆太久"
    },
    {
      "start": 1203.67,
      "end": 1207.29,
      "text": "还是狐狸乖 现在还在这"
    },
    {
      "start": 1231.44,
      "end": 1233.44,
      "text": "这里还是神社"
    },
    {
      "start": 1239.98,
      "end": 1241.48,
      "text": "回来来来来"
    },
    {
      "start": 1241.48,
      "end": 1246.48,
      "text": "我跟你说我这个决策还是非常正确的"
    },
    {
      "start": 1246.48,
      "end": 1249.38,
      "text": "那么早回川陆真的身边有十几感"
    },
    {
      "start": 1249.38,
      "end": 1251.08,
      "text": "还没有酒店住房"
    },
    {
      "start": 1251.08,
      "end": 1253.08,
      "text": "那么我就在这边等车了"
    },
    {
      "start": 1253.08,
      "end": 1255.27,
      "text": "马上要去东京"
    },
    {
      "start": 1255.27,
      "end": 1260.66,
      "text": "又从农村进入大城市"
    }
  ],
