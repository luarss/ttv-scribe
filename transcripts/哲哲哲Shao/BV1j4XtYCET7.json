    {
      "start": 778.39,
      "end": 783.83,
      "text": "特區線"
    },
    {
      "start": 783.83,
      "end": 785.33,
      "text": "3點才有公交"
    },
    {
      "start": 785.33,
      "end": 787.37,
      "text": "算了先走進去"
