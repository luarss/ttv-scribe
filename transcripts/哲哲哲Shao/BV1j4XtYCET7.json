    {
      "start": 907.11,
      "end": 909.1700000000001,
      "text": "倒動了"
    },
    {
      "start": 909.1700000000001,
      "end": 911.1700000000001,
      "text": "我以為地圖看起來有房子"
    },
    {
      "start": 911.1700000000001,
      "end": 914.23,
      "text": "至少是一個有交通的地方"
