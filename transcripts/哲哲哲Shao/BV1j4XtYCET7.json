    {
      "start": 870.4100000000001,
      "end": 886.51,
      "text": "沒過七萬"
    },
    {
      "start": 886.51,
      "end": 888.38,
      "text": "唉"
    },
    {
      "start": 888.38,
      "end": 889.38,
      "text": "我衝了"
    },
    {
      "start": 889.38,
      "end": 895.0899999999999,
      "text": "來看看合影"
    },
    {
      "start": 901.44,
      "end": 902.63,
      "text": "芬達"
    },
    {
      "start": 904.73,
      "end": 907.11,
      "text": "是我太高估"
