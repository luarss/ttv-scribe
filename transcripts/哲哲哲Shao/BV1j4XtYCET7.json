    {
      "start": 943.96,
      "end": 946.25,
      "text": "我這次瘋了我今天"
    },
    {
      "start": 946.25,
      "end": 947.25,
      "text": "大家不要學我"
    },
    {
      "start": 947.25,
      "end": 950.25,
      "text": "已經是我不遵守規則的報應"
