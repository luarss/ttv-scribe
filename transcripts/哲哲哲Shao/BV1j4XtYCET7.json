    {
      "start": 916.23,
      "end": 921.46,
      "text": "小新家"
    },
    {
      "start": 921.46,
      "end": 923.46,
      "text": "如果我在原地等的話"
    },
    {
      "start": 923.46,
      "end": 925.46,
      "text": "我得等到3點多才會有一輛"
    },
    {
      "start": 925.46,
      "end": 928.46,
      "text": "我今天坐過來那輛"
    },
    {
      "start": 928.46,
      "end": 929.46,
      "text": "鶴居線"
    },
    {
      "start": 929.46,
      "end": 931.46,
      "text": "但是我就要在這裡站兩個小時"
    },
    {
      "start": 931.46,
      "end": 934.46,
      "text": "但是我現在離最近的鎮壓站"
