    {
      "start": 792.84,
      "end": 794.34,
      "text": "自找苦吃"
    },
    {
      "start": 795.34,
      "end": 807.1800000000001,
      "text": "這命好苦"
    },
    {
      "start": 807.1800000000001,
      "end": 822.49,
      "text": "這水泉好像都白了"
    },
    {
      "start": 826.8,
      "end": 827.8,
      "text": "其實也不是冷"
