    {
      "start": 1932.57,
      "end": 1935.29,
      "text": "它不太适合干皮"
    },
    {
      "start": 1935.29,
      "end": 1937.25,
      "text": "但我觉得夏天用刚刚好"
    },
    {
      "start": 1938.16,
      "end": 1939.52,
      "text": "金花是这个"
    },
    {
      "start": 1939.92,
      "end": 1942.2,
      "text": "然后就是上一个眼油"
    },
    {
      "start": 1942.76,
      "end": 1944.92,
      "text": "就是其实面霜我两个都有用"
