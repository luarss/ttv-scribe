    {
      "start": 1426.06,
      "end": 1426.8600000000001,
      "text": "很喜歡"
    },
    {
      "start": 1426.8600000000001,
      "end": 1428.66,
      "text": "然後我之前不是有一塊"
    },
    {
      "start": 1428.66,
      "end": 1430.26,
      "text": "橙花味的精油嗎"
    },
    {
      "start": 1430.26,
      "end": 1430.8600000000001,
      "text": "又完了"
    },
    {
      "start": 1430.8600000000001,
      "end": 1432.8600000000001,
      "text": "這次等的是一個天主款的"
    },
    {
      "start": 1433.06,
      "end": 1435.66,
      "text": "今天下午準備去找會子"
    },
    {
      "start": 1435.66,
      "end": 1437.26,
      "text": "上衣穿的是一個吊帶"
    },
    {
      "start": 1437.26,
      "end": 1439.66,
      "text": "是一個那種棉麻的感覺"
    },
    {
      "start": 1440.18,
      "end": 1442.58,
      "text": "我身上這個褲子還蠻喜歡的"
    },
    {
      "start": 1442.98,
      "end": 1443.78,
      "text": "非常的有趣"
    },
    {
      "start": 1443.78,
      "end": 1444.58,
      "text": "就是感覺"
    },
    {
      "start": 1444.58,
      "end": 1446.38,
      "text": "因為我也不是經常的能"
    },
    {
      "start": 1446.38,
      "end": 1448.78,
      "text": "跟朋友們這樣子見面聊天"
    },
    {
      "start": 1448.78,
      "end": 1450.58,
      "text": "所以每一次見面的話"
    },
    {
      "start": 1450.58,
      "end": 1451.58,
      "text": "我還蠻開心的"
    },
    {
      "start": 1451.58,
      "end": 1453.58,
      "text": "只可以把最近自己的鏡框"
    },
    {
      "start": 1453.58,
      "end": 1455.18,
      "text": "還有對方的鏡框這樣聊一聊"
    },
    {
      "start": 1455.18,
      "end": 1457.18,
      "text": "我們今天約的是下午三點鐘"
    },
    {
      "start": 1457.18,
      "end": 1458.38,
      "text": "因為我昨天就在跟大家說"
    },
    {
      "start": 1458.38,
      "end": 1459.98,
      "text": "我說現在上海這個天氣"
    },
    {
      "start": 1459.98,
      "end": 1461.38,
      "text": "實在是太烈了"
    },
    {
      "start": 1461.38,
      "end": 1463.58,
      "text": "就是下午三四點左右"
    },
    {
      "start": 1463.58,
      "end": 1466.38,
      "text": "那個光還烈得跟中午一樣"
    },
    {
      "start": 1467.18,
      "end": 1468.18,
      "text": "就是夏天"
    },
    {
      "start": 1468.18,
      "end": 1469.58,
      "text": "夏天真的是來了"
    },
    {
      "start": 1469.98,
      "end": 1474.34,
      "text": "好看"
    },
    {
      "start": 1474.34,
      "end": 1475.1399999999999,
      "text": "好美"
    },
    {
      "start": 1476.1399999999999,
      "end": 1477.74,
      "text": "我們今天約在這裡"
    },
    {
      "start": 1481.29,
      "end": 1494.16,
      "text": "非常的假"
    }
  ],
