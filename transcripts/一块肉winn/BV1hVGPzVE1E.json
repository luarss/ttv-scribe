    },
    {
      "start": 686.5,
      "end": 689.8199999999999,
      "text": "這個重知識蛋糕"
    },
    {
      "start": 689.8199999999999,
      "end": 692.46,
      "text": "這然是我以前非常愛吃的"
    },
    {
      "start": 692.46,
      "end": 695.14,
      "text": "對以前在上班的時候"
    },
    {
      "start": 695.14,
      "end": 698.3,
      "text": "然後下午我跟我同事"
