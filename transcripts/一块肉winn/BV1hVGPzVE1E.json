    {
      "start": 701.38,
      "end": 703.3,
      "text": "給大家看我的app的殼子"
    },
    {
      "start": 703.3,
      "end": 705.78,
      "text": "就很方便是我新換的一個"
    },
    {
      "start": 706.74,
      "end": 707.54,
      "text": "你好"
    },
    {
      "start": 707.54,
      "end": 708.54,
      "text": "你好"
    },
    {
      "start": 708.54,
      "end": 710.3,
      "text": "謝謝"
    },
    {
      "start": 710.3,
      "end": 726.14,
      "text": "我今天做了酸奶"
    },
    {
      "start": 726.14,
      "end": 727.66,
      "text": "然後需要過濾一下"
    },
    {
      "start": 727.66,
      "end": 730.02,
      "text": "就是把它放進去一個晚上"
    },
    {
      "start": 730.02,
      "end": 732.5,
      "text": "然後它那個乳清就會出來"
    },
    {
      "start": 732.5,
      "end": 735.83,
      "text": "完了之後就是吸完酸奶"
    },
    {
      "start": 735.83,
      "end": 737.47,
      "text": "我發現我吃"
    },
    {
      "start": 737.47,
      "end": 740.03,
      "text": "真的喜歡吃這種酸奶碗"
    },
    {
      "start": 740.03,
