    {
      "start": 940.6800000000001,
      "end": 949.31,
      "text": "夏天可以帶出去用"
    },
    {
      "start": 949.31,
      "end": 951.35,
      "text": "熱拿鐵"
    },
    {
      "start": 951.35,
      "end": 954.71,
      "text": "這是我朋友自己做的那個芝麻滿泡"
