    {
      "start": 793.69,
      "end": 795.65,
      "text": "是跟翻Print的特別像"
    },
    {
      "start": 795.65,
      "end": 798.45,
      "text": "就是Rocoto Cheese上面加了那個藍莓"
    },
    {
      "start": 798.45,
      "end": 799.65,
      "text": "然後我就很想吃"
    },
    {
      "start": 799.65,
      "end": 801.61,
      "text": "然後我今天就正好沒有喝咖啡"
